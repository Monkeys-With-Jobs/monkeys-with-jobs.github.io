---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import { Image } from 'astro:assets';
import logoWhite from '../../assets/dyer-expedition/logo-white.svg';
import '@fortawesome/fontawesome-free/css/all.min.css'
---

<style scoped>
  iframe {
    height: 100%;
    width: 100%;
  }
</style>

<DefaultLayout>
  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <Image class="w-full max-w-md mx-auto mb-6" src={logoWhite} alt="Dyer Expedition Logo" width={680} height={514} />
            <h1 class="sr-only">Dyer Expedition</h1>

            <div class="flex flex-wrap gap-4 justify-center mt-6">
              <a href="https://store.steampowered.com/app/2179390/Dyer_Expedition/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-secondary bg-primary hover:bg-primary/80 transition-colors duration-300 no-underline">
                <i class="fa-brands fa-steam mr-2"></i> View on Steam
              </a>
            </div>
          </div>
          <div class="aspect-video">
            <iframe class="w-full h-full rounded-lg shadow-lg" src="https://www.youtube-nocookie.com/embed/aoKi-mzx9n0" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Game Description -->
  <section class="py-16 bg-secondary">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="mx-auto">
          <p class="text-xl leading-relaxed text-gray-300">
            Dyer Expedition is a puzzle adventure game with light Lovecraftian horror elements. The story is inspired by Lovecraft's At the Mountains of Madness. It's 1931 and the protagonist (you) is a professor at the Miskatonic University whose colleagues have gone missing on an expedition to the Antarctic. The protagonist not only fears the worst for their colleagues but they also have an inexplicable sense of dread surrounding the expedition. Without support from the university anytime soon, you begin your rogue mission to find out what happened to them. You make your way to Australia and find a fishing boat that is willing to drop you off and pick you back up after two days. As you arrive at the shore you discover an abandoned base camp.
          </p>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
